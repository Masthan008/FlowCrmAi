// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 1. ROLES
model Role {
  id          String           @id @default(uuid()) @db.Uuid
  name        String           @unique
  description String?
  
  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  version     Int              @default(1)

  // Relations
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

// 2. PERMISSIONS
model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  name        String           @unique
  module      String
  action      String
  description String?

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  version     Int              @default(1)

  // Relations
  roles       RolePermission[]

  @@map("permissions")
}

// 3. ROLE PERMISSIONS
model RolePermission {
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid
  
  // Relations
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  version     Int              @default(1)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// 4. USERS
model User {
  id              String          @id @default(uuid()) @db.Uuid
  email           String          @unique
  password        String
  firstName       String
  lastName        String
  fullName        String?
  phone           String?
  profileImage    String?
  department      String?
  jobTitle        String?
  status          String          @default("active")
  roleId          String          @db.Uuid
  role            Role            @relation(fields: [roleId], references: [id], onDelete: Restrict)
  emailVerified   Boolean         @default(false)
  phoneVerified   Boolean         @default(false)
  timezone        String          @default("UTC")
  language        String          @default("en")
  themePreference String          @default("white-glossy")
  lastLogin       DateTime?

  // Auditing
  createdBy    String?
  updatedBy    String?
  deletedBy    String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?
  version      Int             @default(1)

  // Relations
  preferences  UserPreference?
  sessions     Session[]
  apiKeys      ApiKey[]
  employee     Employee?
  notifications Notification[]
  auditLogs    AuditLog[]
  comments     Comment[]
  loginHistories LoginHistory[]
  passwordResets PasswordReset[]
  refreshTokens  RefreshToken[]
  taskTimelines  TaskTimeline[]
  savedViews     SavedView[]
  importLogs     LeadImportLog[]
  exportLogs     LeadExportLog[]

  @@index([email])
  @@index([phone])
  @@index([status])
  @@index([createdAt])
  @@map("users")
}

// 5. USER PREFERENCES
model UserPreference {
  id                   String    @id @default(uuid()) @db.Uuid
  userId               String    @unique @db.Uuid
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme                String    @default("white-glossy")
  language             String    @default("en")
  timezone             String    @default("UTC")
  compactMode          Boolean   @default(false)
  notificationsEnabled Boolean   @default(true)

  // Auditing
  createdBy            String?
  updatedBy            String?
  deletedBy            String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?
  version              Int       @default(1)

  @@map("user_preferences")
}

// 6. SESSIONS
model Session {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String    @unique
  userAgent    String?
  ipAddress    String?
  deviceInfo   String?
  expiresAt    DateTime
  isValid      Boolean   @default(true)

  // Auditing
  createdBy    String?
  updatedBy    String?
  deletedBy    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  version      Int       @default(1)

  @@map("sessions")
}

// 7. API KEYS
model ApiKey {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  key         String    @unique
  expiresAt   DateTime?
  isActive    Boolean   @default(true)

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  version     Int       @default(1)

  @@map("api_keys")
}

// 8. COMPANIES
model Company {
  id              String     @id @default(uuid()) @db.Uuid
  companyNumber   String     @unique
  name            String
  legalName       String?
  displayName     String?
  logo            String?
  companyType     String?
  industry        String?
  subIndustry     String?
  businessCategory String?
  website         String?
  primaryEmail    String?
  secondaryEmail  String?
  primaryPhone    String?
  secondaryPhone  String?
  whatsApp        String?
  gstNumber       String?
  taxNumber       String?
  registrationNumber String?
  panNumber       String?
  foundedYear     Int?
  annualRevenue   Float?
  employeeCount   Int?
  ownershipType   String?
  currency        String?    @default("USD")
  timezone        String?    @default("UTC")
  primaryLanguage String?    @default("en")
  country         String?
  state           String?
  city            String?
  postalCode      String?
  addressLine1    String?
  addressLine2    String?
  billingAddress  String?
  shippingAddress String?
  status          String     @default("Prospect")
  priority        String     @default("Medium")
  rating          Int        @default(0)
  lifecycleStage  String     @default("Prospect")
  ownerId         String?    @db.Uuid
  parentCompanyId String?    @db.Uuid
  description     String?    @db.Text
  tags            String[]   @default([])

  // Communication Preferences
  preferredContactMethod String?  @default("email")
  preferredLanguage      String?  @default("en")
  businessHours          String?
  marketingConsent       Boolean? @default(false)
  newsletterConsent      Boolean? @default(false)
  notificationPrefs      Json?    @default("{}")

  // Relations
  parentCompany   Company?   @relation("ParentCompany", fields: [parentCompanyId], references: [id], onDelete: SetNull)
  subsidiaries    Company[]  @relation("ParentCompany")
  owner           Employee?  @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  branches        Branch[]
  employees       Employee[]
  customers       Customer[]
  tasks           Task[]
  contacts        Contact[]       @relation("CompanyContacts")
  deals           Deal[]
  companyNotes    CompanyNote[]
  companyActivities CompanyActivity[]
  companyFiles    CompanyFile[]
  companyTimelines CompanyTimeline[]
  companyHistories  CompanyHistory[]
  departments       CompanyDepartment[]
  hierarchyEntries  CompanyHierarchy[]
  hierarchyParents  CompanyHierarchy[] @relation("HierarchyParentCompany")
  businessNetwork   CompanyBusinessNetwork[]
  bizNetworkRelated CompanyBusinessNetwork[] @relation("BizNetworkRelatedCompanies")
  revenues          CompanyRevenue[]
  journey           CompanyCustomerJourney[]

  // Phase 6 Relations
  lifecycle        CompanyLifecycle?
  stageHistory     CompanyStageHistory[]
  score            CompanyScore?
  health           CompanyHealth?
  risk             CompanyRisk?
  segmentMappings  CompanySegmentMapping[]  @relation("CompanySegments")
  tagMappings      CompanyTagMapping[]
  workflows        CompanyWorkflow[]
  recommendations CompanyRecommendation[]
  followups        CompanyFollowup[]

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  version     Int        @default(1)

  @@index([name])
  @@index([companyNumber])
  @@index([primaryEmail])
  @@index([primaryPhone])
  @@index([gstNumber])
  @@index([lifecycleStage])
  @@index([registrationNumber])
  @@index([status])
  @@index([industry])
  @@index([country])
  @@index([state])
  @@index([city])
  @@index([ownerId])
  @@index([createdAt])
  @@map("companies")
}

// 9. BRANCHES
model Branch {
  id            String     @id @default(uuid()) @db.Uuid
  companyId     String     @db.Uuid
  company       Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name          String
  branchCode    String?
  branchType    String?    // Head Office, Regional Office, Branch Office, Franchise, Business Unit
  managerId     String?    @db.Uuid
  phone         String?
  email         String?
  address       String?
  gst           String?
  country       String?
  state         String?
  city          String?
  employeeCount Int        @default(0)
  revenue       Float      @default(0.0)
  status        String     @default("Active")
  openingDate   DateTime?
  timezone      String?

  // Auditing
  createdBy     String?
  updatedBy     String?
  deletedBy     String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?
  version       Int        @default(1)

  @@map("branches")
}

model CompanyDepartment {
  id          String     @id @default(uuid()) @db.Uuid
  companyId   String     @db.Uuid
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String     // Sales, Marketing, Finance, HR, Support, IT, Operations, Legal, or Custom
  type        String     @default("Custom") // Sales, Marketing, Finance, HR, Support, IT, Operations, Legal, Custom
  managerId   String?    @db.Uuid
  description String?    @db.Text
  revenue     Float      @default(0.0)
  status      String     @default("Active")
  employeeCount Int      @default(0)

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  version     Int        @default(1)

  @@index([companyId])
  @@index([type])
  @@map("company_departments")
}

model CompanyHierarchy {
  id              String     @id @default(uuid()) @db.Uuid
  companyId       String     @db.Uuid
  company         Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parentCompanyId String?    @db.Uuid
  parentCompany   Company?   @relation("HierarchyParentCompany", fields: [parentCompanyId], references: [id], onDelete: SetNull)
  relationshipType String    // Subsidiary, Branch Office, Regional Office, Head Office, Franchise, Business Unit, Joint Venture, Partner Organization
  level           Int        @default(0)
  description     String?    @db.Text

  // Auditing
  createdBy       String?
  updatedBy       String?
  deletedBy       String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?
  version         Int        @default(1)

  @@index([companyId])
  @@index([parentCompanyId])
  @@index([relationshipType])
  @@map("company_hierarchy")
}

model CompanyBusinessNetwork {
  id                String     @id @default(uuid()) @db.Uuid
  companyId         String     @db.Uuid
  company           Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  relatedCompanyId  String?    @db.Uuid
  relatedCompany  Company?   @relation("BizNetworkRelatedCompanies", fields: [relatedCompanyId], references: [id], onDelete: SetNull)
  name              String
  relationshipType  String     // Partner, Supplier, Distributor, Reseller, Affiliate, Strategic Alliance, Linked Company
  description       String?    @db.Text
  status            String     @default("Active")
  website           String?

  // Auditing
  createdBy         String?
  updatedBy         String?
  deletedBy         String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  deletedAt         DateTime?
  version           Int        @default(1)

  @@index([companyId])
  @@index([relationshipType])
  @@map("company_business_network")
}

model CompanyRevenue {
  id          String     @id @default(uuid()) @db.Uuid
  companyId   String     @db.Uuid
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period      String     // Monthly, Quarterly, Annual
  year        Int
  month       Int?
  quarter     Int?
  amount      Float      @default(0.0)
  type        String     @default("Revenue") // Revenue, Expense, Profit
  description String?    @db.Text

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  version     Int        @default(1)

  @@index([companyId, period, year])
  @@index([companyId, type])
  @@map("company_revenue")
}

model CompanyCustomerJourney {
  id          String     @id @default(uuid()) @db.Uuid
  companyId   String     @db.Uuid
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type        String     // Lead Created, Company Registered, First Contact, First Meeting, First Deal, Quote Generated, Invoice Generated, Payment Received, Renewal, Expansion, Support Case, Relationship Milestone
  title       String
  description String?    @db.Text
  eventDate   DateTime   @default(now())
  icon        String?
  color       String?
  metadata    String?    @db.Text // JSON for extra data

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  version     Int        @default(1)

  @@index([companyId])
  @@index([type])
  @@map("company_customer_journey")
}

// 10. EMPLOYEES
model Employee {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String?       @unique @db.Uuid
  user        User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  companyId   String        @db.Uuid
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  firstName   String
  lastName    String
  email       String
  phone       String?
  department  String?
  designation String?

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  version     Int           @default(1)

  // Relations
  ownedCompanies Company[]  @relation("CompanyOwner")
  teamLeaders Team[]        @relation("TeamLeader")
  teamMembers TeamMember[]
  leads       Lead[]
  deals       Deal[]
  activities  Activity[]
  assignedTasks Task[]      @relation("TaskAssignedTo")
  delegatedTasks Task[]     @relation("TaskAssignedBy")
  meetings    Meeting[]
  leadActivities LeadActivity[]
  subtasks      TaskSubtask[]
  timeLogs      TaskTimeLog[]
  watchedTasks  TaskWatcher[]
  approvals     TaskApproval[]
  taskNotifications TaskNotification[]
  previousLeads     Lead[]             @relation("LeadPreviousOwner")
  leadAssignments   LeadAssignment[]
  leadFollowups     LeadFollowup[]
  leadApprovals     LeadApproval[]
  leadNotifications LeadNotification[]
  contacts          Contact[]          @relation("ContactOwner")
  contactActivities ContactActivity[]
  companyActivities CompanyActivity[]
  companyFollowups  CompanyFollowup[]
  dealActivities    DealActivity[]
  dealQuotas        DealQuota[]
  dealPipelineViews DealPipelineView[]
  dealComments      DealComment[]
  dealTeamMembers   DealTeamMember[]
  dealApprovals     DealApproval[]     @relation("DealApprover")

  @@map("employees")
}

// 11. TEAMS
model Team {
  id          String       @id @default(uuid()) @db.Uuid
  name        String
  description String?
  leaderId    String       @db.Uuid
  leader      Employee     @relation("TeamLeader", fields: [leaderId], references: [id], onDelete: Restrict)

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?
  version       Int          @default(1)

  // Relations
  members     TeamMember[]

  @@map("teams")
}

// 12. TEAM MEMBERS
model TeamMember {
  id          String    @id @default(uuid()) @db.Uuid
  teamId      String    @db.Uuid
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  employeeId  String    @db.Uuid
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  version     Int       @default(1)

  @@map("team_members")
}

// 13. CUSTOMERS
model Customer {
  id          String     @id @default(uuid()) @db.Uuid
  companyId   String?    @db.Uuid
  company     Company?   @relation(fields: [companyId], references: [id], onDelete: SetNull)
  name        String
  email       String?
  phone       String?
  type        String     @default("lead") // lead / client
  status      String     @default("active")

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  version     Int        @default(1)

  // Relations
  contacts    Contact[]
  leads       Lead[]
  deals       Deal[]
  activities  Activity[]
  tasks       Task[]
  meetings    Meeting[]
  quotes      Quote[]
  invoices    Invoice[]

  @@index([name])
  @@index([email])
  @@index([phone])
  @@index([status])
  @@map("customers")
}

// 14. CONTACTS
model Contact {
  id                     String           @id @default(uuid()) @db.Uuid
  contactNumber          String           @unique
  firstName              String
  middleName             String?
  lastName               String
  fullName               String
  profilePhoto           String?
  gender                 String?
  dateOfBirth            DateTime?
  jobTitle               String?
  department             String?
  
  // Relations
  companyId              String?          @db.Uuid
  company                Company?         @relation("CompanyContacts", fields: [companyId], references: [id], onDelete: SetNull)
  
  leadId                 String?          @db.Uuid
  lead                   Lead?            @relation("LeadContacts", fields: [leadId], references: [id], onDelete: SetNull)
  
  customerId             String?          @db.Uuid
  customer               Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)

  // Communication
  email                  String?
  secondaryEmail         String?
  phone                  String?
  alternatePhone         String?
  whatsApp               String?
  website                String?
  
  // Social Profiles
  linkedin               String?
  twitter                String?
  facebook               String?
  instagram              String?
  
  // Address
  country                String?
  state                  String?
  city                   String?
  postalCode             String?
  addressLine1           String?
  addressLine2           String?
  
  // Status
  status                 String           @default("Active") // Active, Inactive, VIP, Prospect, Customer, Partner, Vendor, Former Customer, Archived
  
  // Owner (Employee)
  ownerId                String?          @db.Uuid
  owner                  Employee?        @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  
  // Preferences
  preferredLanguage      String?          @default("en")
  preferredContactMethod String?          @default("Email")
  timezone               String?          @default("UTC")
  
  // Tags & Notes
  tags                   String[]         @default([])
  description            String?          @db.Text
  
  // Auditing
  createdBy              String?
  updatedBy              String?
  deletedBy              String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  deletedAt              DateTime?
  version                Int              @default(1)
  
  // Relations
  tasks                  Task[]
  notes                  ContactNote[]
  activities             ContactActivity[]
  files                  ContactFile[]
  timeline               ContactTimeline[]
  history                ContactHistory[]
  relationships          ContactRelationship[]
  calls                  ContactCall[]
  deals                  Deal[]
  emailsLogs             ContactEmailLog[]
  whatsappLogs           ContactWhatsAppLog[]
  meetingsLogs           ContactMeetingLog[]
  businessMetric         ContactBusinessMetric?
  healthMetric           ContactHealth?
  engagementMetric       ContactEngagement?
  lifecycle              ContactLifecycle?
  stageHistory           ContactStageHistory[]
  preference             ContactPreference?
  tagMappings            ContactTagMapping[]
  followups              ContactFollowUp[]
  scores                 ContactScore?
  riskMetric             ContactRisk?
  recommendations        ContactRecommendation[]

  @@index([email])
  @@index([phone])
  @@index([contactNumber])
  @@index([fullName])
  @@index([status])
  @@map("contacts")
}

// 15. LEAD SOURCES
model LeadSource {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  version     Int       @default(1)

  // Relations
  leads       Lead[]

  @@map("lead_sources")
}

// 16. LEAD STATUS
model LeadStatus {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  description String?
  color       String    @default("#6B7280")
  order       Int       @default(0)
  isActive    Boolean   @default(true)

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  version     Int       @default(1)

  // Relations
  leads       Lead[]

  @@map("lead_status")
}

// 17. LEADS
model Lead {
  id                 String      @id @default(uuid()) @db.Uuid
  leadNumber         String      @unique
  customerId         String?     @db.Uuid
  customer           Customer?   @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // Personal Information
  firstName          String
  lastName           String
  fullName           String
  email              String?
  phone              String?
  alternatePhone     String?
  jobTitle           String?

  // Company Information
  companyName        String?
  industry           String?
  website            String?

  // Address
  address            String?
  city               String?
  state              String?
  country            String?
  postalCode         String?

  // Lead Classification
  sourceId           String?     @db.Uuid
  source             LeadSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  statusId           String?     @db.Uuid
  status             LeadStatus? @relation(fields: [statusId], references: [id], onDelete: SetNull)
  assignedToId       String?     @db.Uuid
  assignedTo         Employee?   @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  priority           String      @default("Medium")
  rating             Int         @default(0)
  value              Float       @default(0.0)
  expectedClosingDate DateTime?
  description        String?

  // Auditing
  createdBy          String?
  updatedBy          String?
  deletedBy          String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  deletedAt          DateTime?
  version            Int         @default(1)

  // Extra fields & relations
  socialLinks        Json?
  notes              LeadNote[]
  activities         LeadActivity[]
  files              LeadFile[]
  timeline           LeadTimeline[]
  history            LeadHistory[]
  tasks              Task[]
  isFavorite         Boolean           @default(false)
  archivedAt         DateTime?
  archivedBy         String?
  tagMappings        LeadTagMapping[]
  mergeHistories     LeadMergeHistory[] @relation("PrimaryMerge")
  duplicates1        LeadDuplicate[]    @relation("LeadDup1")
  duplicates2        LeadDuplicate[]    @relation("LeadDup2")
  previousOwnerId    String?            @db.Uuid
  previousOwner      Employee?          @relation("LeadPreviousOwner", fields: [previousOwnerId], references: [id], onDelete: SetNull)
  assignedDate       DateTime?
  assignmentReason   String?
  assignments        LeadAssignment[]
  followups          LeadFollowup[]
  conversions        LeadConversionHistory[]
  workflows          LeadWorkflow[]
  score              LeadScore?
  health             LeadHealth?
  sla                LeadSla?
  approvals          LeadApproval[]
  contacts           Contact[]         @relation("LeadContacts")
  deals              Deal[]

  @@index([leadNumber])
  @@index([fullName])
  @@index([email])
  @@index([phone])
  @@index([companyName])
  @@index([statusId])
  @@index([sourceId])
  @@index([assignedToId])
  @@index([priority])
  @@index([createdAt])
  @@map("leads")
}

// 18. PIPELINES
model Pipeline {
  id          String          @id @default(uuid()) @db.Uuid
  name        String
  description String?
