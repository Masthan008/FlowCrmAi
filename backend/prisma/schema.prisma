  quotes          Quote[]
  invoices        Invoice[]
  dealNotes       DealNote[]
  dealActivities  DealActivity[]
  dealFiles       DealFile[]
  dealTimeline    DealTimeline[]
  dealHistory     DealHistory[]
  dealProducts    DealProduct[]
  dealQuotes      DealQuote[]
  stageHistory    DealStageHistory[]
