// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 1. ROLES
model Role {
  id          String           @id @default(uuid()) @db.Uuid
  name        String           @unique
  description String?
  
  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  version     Int              @default(1)

  // Relations
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

// 2. PERMISSIONS
model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  name        String           @unique
  module      String
  action      String
  description String?

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  version     Int              @default(1)

  // Relations
  roles       RolePermission[]

  @@map("permissions")
}

// 3. ROLE PERMISSIONS
model RolePermission {
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid
  
  // Relations
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  version     Int              @default(1)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// 4. USERS
model User {
  id              String          @id @default(uuid()) @db.Uuid
  email           String          @unique
  password        String
  firstName       String
  lastName        String
  fullName        String?
  phone           String?
  profileImage    String?
  department      String?
  jobTitle        String?
  status          String          @default("active")
  roleId          String          @db.Uuid
  role            Role            @relation(fields: [roleId], references: [id], onDelete: Restrict)
  emailVerified   Boolean         @default(false)
  phoneVerified   Boolean         @default(false)
  timezone        String          @default("UTC")
  language        String          @default("en")
  themePreference String          @default("white-glossy")
  lastLogin       DateTime?

  // Auditing
  createdBy    String?
  updatedBy    String?
  deletedBy    String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?
  version      Int             @default(1)

  // Relations
  preferences  UserPreference?
  sessions     Session[]
  apiKeys      ApiKey[]
  employee     Employee?
  notifications Notification[]
  auditLogs    AuditLog[]
  comments     Comment[]
  loginHistories LoginHistory[]
  passwordResets PasswordReset[]
  refreshTokens  RefreshToken[]
  taskTimelines  TaskTimeline[]
  savedViews     SavedView[]
  importLogs     LeadImportLog[]
  exportLogs     LeadExportLog[]

  @@index([email])
  @@index([phone])
  @@index([status])
  @@index([createdAt])
  @@map("users")
}

// 5. USER PREFERENCES
model UserPreference {
  id                   String    @id @default(uuid()) @db.Uuid
  userId               String    @unique @db.Uuid
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme                String    @default("white-glossy")
  language             String    @default("en")
  timezone             String    @default("UTC")
  compactMode          Boolean   @default(false)
  notificationsEnabled Boolean   @default(true)

  // Auditing
  createdBy            String?
  updatedBy            String?
  deletedBy            String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?
  version              Int       @default(1)

  @@map("user_preferences")
}

// 6. SESSIONS
model Session {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String    @unique
  userAgent    String?
  ipAddress    String?
  deviceInfo   String?
  expiresAt    DateTime
  isValid      Boolean   @default(true)

  // Auditing
  createdBy    String?
  updatedBy    String?
  deletedBy    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  version      Int       @default(1)

  @@map("sessions")
}

// 7. API KEYS
model ApiKey {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  key         String    @unique
  expiresAt   DateTime?
  isActive    Boolean   @default(true)

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  version     Int       @default(1)

  @@map("api_keys")
}

// 8. COMPANIES
model Company {
  id          String     @id @default(uuid()) @db.Uuid
  name        String
  domain      String?
  phone       String?
  industry    String?
  status      String     @default("active")

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  version     Int        @default(1)

  // Relations
  branches    Branch[]
  employees   Employee[]
  customers   Customer[]
  tasks       Task[]
  contacts    Contact[]  @relation("CompanyContacts")

  @@index([name])
  @@index([phone])
  @@index([status])
  @@map("companies")
}

// 9. BRANCHES
model Branch {
  id          String     @id @default(uuid()) @db.Uuid
  companyId   String     @db.Uuid
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  phone       String?
  address     String?

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  version     Int        @default(1)

  @@map("branches")
}

// 10. EMPLOYEES
model Employee {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String?       @unique @db.Uuid
  user        User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  companyId   String        @db.Uuid
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  firstName   String
  lastName    String
  email       String
  phone       String?
  department  String?
  designation String?

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  version     Int           @default(1)

  // Relations
  teamLeaders Team[]        @relation("TeamLeader")
  teamMembers TeamMember[]
  leads       Lead[]
  deals       Deal[]
  activities  Activity[]
  assignedTasks Task[]      @relation("TaskAssignedTo")
  delegatedTasks Task[]     @relation("TaskAssignedBy")
  meetings    Meeting[]
  leadActivities LeadActivity[]
  subtasks      TaskSubtask[]
  timeLogs      TaskTimeLog[]
  watchedTasks  TaskWatcher[]
  approvals     TaskApproval[]
  taskNotifications TaskNotification[]
  previousLeads     Lead[]             @relation("LeadPreviousOwner")
  leadAssignments   LeadAssignment[]
  leadFollowups     LeadFollowup[]
  leadApprovals     LeadApproval[]
  leadNotifications LeadNotification[]
  contacts          Contact[]          @relation("ContactOwner")
  contactActivities ContactActivity[]

  @@map("employees")
}

// 11. TEAMS
model Team {
  id          String       @id @default(uuid()) @db.Uuid
  name        String
  description String?
  leaderId    String       @db.Uuid
  leader      Employee     @relation("TeamLeader", fields: [leaderId], references: [id], onDelete: Restrict)

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?
  version       Int          @default(1)

  // Relations
  members     TeamMember[]

  @@map("teams")
}

// 12. TEAM MEMBERS
model TeamMember {
  id          String    @id @default(uuid()) @db.Uuid
  teamId      String    @db.Uuid
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  employeeId  String    @db.Uuid
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  version     Int       @default(1)

  @@map("team_members")
}

// 13. CUSTOMERS
model Customer {
  id          String     @id @default(uuid()) @db.Uuid
  companyId   String?    @db.Uuid
  company     Company?   @relation(fields: [companyId], references: [id], onDelete: SetNull)
  name        String
  email       String?
  phone       String?
  type        String     @default("lead") // lead / client
  status      String     @default("active")

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  version     Int        @default(1)

  // Relations
  contacts    Contact[]
  leads       Lead[]
  deals       Deal[]
  activities  Activity[]
  tasks       Task[]
  meetings    Meeting[]
  quotes      Quote[]
  invoices    Invoice[]

  @@index([name])
  @@index([email])
  @@index([phone])
  @@index([status])
  @@map("customers")
}

// 14. CONTACTS
model Contact {
  id                     String           @id @default(uuid()) @db.Uuid
  contactNumber          String           @unique
  firstName              String
  middleName             String?
  lastName               String
  fullName               String
  profilePhoto           String?
  gender                 String?
  dateOfBirth            DateTime?
  jobTitle               String?
  department             String?
  
  // Relations
  companyId              String?          @db.Uuid
  company                Company?         @relation("CompanyContacts", fields: [companyId], references: [id], onDelete: SetNull)
  
  leadId                 String?          @db.Uuid
  lead                   Lead?            @relation("LeadContacts", fields: [leadId], references: [id], onDelete: SetNull)
  
  customerId             String?          @db.Uuid
  customer               Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)

  // Communication
  email                  String?
  secondaryEmail         String?
  phone                  String?
  alternatePhone         String?
  whatsApp               String?
  website                String?
  
  // Social Profiles
  linkedin               String?
  twitter                String?
  facebook               String?
  instagram              String?
  
  // Address
  country                String?
  state                  String?
  city                   String?
  postalCode             String?
  addressLine1           String?
  addressLine2           String?
  
  // Status
  status                 String           @default("Active") // Active, Inactive, VIP, Prospect, Customer, Partner, Vendor, Former Customer, Archived
  
  // Owner (Employee)
  ownerId                String?          @db.Uuid
  owner                  Employee?        @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  
  // Preferences
  preferredLanguage      String?          @default("en")
  preferredContactMethod String?          @default("Email")
  timezone               String?          @default("UTC")
  
  // Tags & Notes
  tags                   String[]         @default([])
  description            String?          @db.Text
  
  // Auditing
  createdBy              String?
  updatedBy              String?
  deletedBy              String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  deletedAt              DateTime?
  version                Int              @default(1)
  
  // Relations
  tasks                  Task[]
  notes                  ContactNote[]
  activities             ContactActivity[]
  files                  ContactFile[]
  timeline               ContactTimeline[]
  history                ContactHistory[]
  relationships          ContactRelationship[]
  calls                  ContactCall[]
  emailsLogs             ContactEmailLog[]
  whatsappLogs           ContactWhatsAppLog[]
  meetingsLogs           ContactMeetingLog[]
  businessMetric         ContactBusinessMetric?
  healthMetric           ContactHealth?
  engagementMetric       ContactEngagement?
  lifecycle              ContactLifecycle?
  stageHistory           ContactStageHistory[]
  preference             ContactPreference?
  tagMappings            ContactTagMapping[]
  followups              ContactFollowUp[]
  scores                 ContactScore?
  riskMetric             ContactRisk?
  recommendations        ContactRecommendation[]

  @@index([email])
  @@index([phone])
  @@index([contactNumber])
  @@index([fullName])
  @@index([status])
  @@map("contacts")
}

// 15. LEAD SOURCES
model LeadSource {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  version     Int       @default(1)

  // Relations
  leads       Lead[]

  @@map("lead_sources")
}

// 16. LEAD STATUS
model LeadStatus {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  description String?
  color       String    @default("#6B7280")
  order       Int       @default(0)
  isActive    Boolean   @default(true)

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  version     Int       @default(1)

  // Relations
  leads       Lead[]

  @@map("lead_status")
}

// 17. LEADS
model Lead {
  id                 String      @id @default(uuid()) @db.Uuid
  leadNumber         String      @unique
  customerId         String?     @db.Uuid
  customer           Customer?   @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // Personal Information
  firstName          String
  lastName           String
  fullName           String
  email              String?
  phone              String?
  alternatePhone     String?
  jobTitle           String?

  // Company Information
  companyName        String?
  industry           String?
  website            String?

  // Address
  address            String?
  city               String?
  state              String?
  country            String?
  postalCode         String?

  // Lead Classification
  sourceId           String?     @db.Uuid
  source             LeadSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  statusId           String?     @db.Uuid
  status             LeadStatus? @relation(fields: [statusId], references: [id], onDelete: SetNull)
  assignedToId       String?     @db.Uuid
  assignedTo         Employee?   @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  priority           String      @default("Medium")
  rating             Int         @default(0)
  value              Float       @default(0.0)
  expectedClosingDate DateTime?
  description        String?

  // Auditing
  createdBy          String?
  updatedBy          String?
  deletedBy          String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  deletedAt          DateTime?
  version            Int         @default(1)

  // Extra fields & relations
  socialLinks        Json?
  notes              LeadNote[]
  activities         LeadActivity[]
  files              LeadFile[]
  timeline           LeadTimeline[]
  history            LeadHistory[]
  tasks              Task[]
  isFavorite         Boolean           @default(false)
  archivedAt         DateTime?
  archivedBy         String?
  tagMappings        LeadTagMapping[]
  mergeHistories     LeadMergeHistory[] @relation("PrimaryMerge")
  duplicates1        LeadDuplicate[]    @relation("LeadDup1")
  duplicates2        LeadDuplicate[]    @relation("LeadDup2")
  previousOwnerId    String?            @db.Uuid
  previousOwner      Employee?          @relation("LeadPreviousOwner", fields: [previousOwnerId], references: [id], onDelete: SetNull)
  assignedDate       DateTime?
  assignmentReason   String?
  assignments        LeadAssignment[]
  followups          LeadFollowup[]
  conversions        LeadConversionHistory[]
  workflows          LeadWorkflow[]
  score              LeadScore?
  health             LeadHealth?
  sla                LeadSla?
  approvals          LeadApproval[]
  contacts           Contact[]         @relation("LeadContacts")

  @@index([leadNumber])
  @@index([fullName])
  @@index([email])
  @@index([phone])
  @@index([companyName])
  @@index([statusId])
  @@index([sourceId])
  @@index([assignedToId])
  @@index([priority])
  @@index([createdAt])
  @@map("leads")
}

// 18. PIPELINES
model Pipeline {
  id          String          @id @default(uuid()) @db.Uuid
  name        String
  description String?

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?
  version     Int             @default(1)

  // Relations
  stages      PipelineStage[]

  @@map("pipelines")
}

// 19. PIPELINE STAGES
model PipelineStage {
  id          String    @id @default(uuid()) @db.Uuid
  pipelineId  String    @db.Uuid
  pipeline    Pipeline  @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  name        String
  order       Int
  probability Float     @default(0.0)

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  version     Int       @default(1)

  // Relations
  deals       Deal[]

  @@map("pipeline_stages")
}

// 20. DEALS
model Deal {
  id           String        @id @default(uuid()) @db.Uuid
  customerId   String        @db.Uuid
  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name         String
  stageId      String        @db.Uuid
  stage        PipelineStage @relation(fields: [stageId], references: [id], onDelete: Restrict)
  assignedToId String?       @db.Uuid
  assignedTo   Employee?     @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  value        Float         @default(0.0)
  closeDate    DateTime?

  // Auditing
  createdBy    String?
  updatedBy    String?
  deletedBy    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  version      Int           @default(1)

  // Relations
  activities   Activity[]
  tasks        Task[]
  meetings     Meeting[]
  quotes       Quote[]
  invoices     Invoice[]

  @@index([name])
  @@index([createdAt])
  @@map("deals")
}

// 21. ACTIVITY TYPES
model ActivityType {
  id          String     @id @default(uuid()) @db.Uuid
  name        String     @unique
  description String?

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  version     Int        @default(1)

  // Relations
  activities  Activity[]

  @@map("activity_types")
}

// 22. ACTIVITIES
model Activity {
  id           String        @id @default(uuid()) @db.Uuid
  customerId   String?       @db.Uuid
  customer     Customer?     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  dealId       String?       @db.Uuid
  deal         Deal?         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  typeId       String        @db.Uuid
  type         ActivityType  @relation(fields: [typeId], references: [id], onDelete: Restrict)
  subject      String
  description  String?
  loggedById   String        @db.Uuid
  loggedBy     Employee      @relation(fields: [loggedById], references: [id], onDelete: Restrict)
  activityDate DateTime

  // Auditing
  createdBy    String?
  updatedBy    String?
  deletedBy    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  version      Int           @default(1)

  @@map("activities")
}

// 23. TASKS
model Task {
  id                 String           @id @default(uuid()) @db.Uuid
  taskNumber         String           @unique
  title              String
  description        String?          @db.Text
  priority           String           @default("Medium") // Critical, High, Medium, Low
  status             String           @default("Pending") // Pending, In Progress, Waiting, Completed, Cancelled, Overdue
  taskType           String           @default("General") // Call, Meeting, Email, Follow-up, Documentation, Sales, Support, General, Custom
  relatedModule      String?          // Leads, Contacts, Companies, Deals, etc.
  relatedRecordId    String?          @db.Uuid

  // Relationships
  leadId             String?          @db.Uuid
  lead               Lead?            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  contactId          String?          @db.Uuid
  contact            Contact?         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  companyId          String?          @db.Uuid
  company            Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId         String?          @db.Uuid
  customer           Customer?        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  dealId             String?          @db.Uuid
  deal               Deal?            @relation(fields: [dealId], references: [id], onDelete: Cascade)
  assignedToId       String           @db.Uuid
  assignedTo         Employee         @relation("TaskAssignedTo", fields: [assignedToId], references: [id], onDelete: Restrict)
  assignedById       String?          @db.Uuid
  assignedBy         Employee?        @relation("TaskAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  comments           TaskComment[]
  attachments        TaskAttachment[]
  subtasks           TaskSubtask[]
  checklists         TaskChecklist[]
  timeLogs           TaskTimeLog[]
  labelMappings      TaskLabelMapping[]
  watchers           TaskWatcher[]
  dependencies       TaskDependency[] @relation("TaskDepends")
  dependentOn        TaskDependency[] @relation("TaskDependsOn")
  recurrence         TaskRecurrence?
  approval           TaskApproval?
  notifications      TaskNotification[]
  timelines          TaskTimeline[]

  // Fields
  department         String?
  startDate          DateTime?
  dueDate            DateTime?
  completedDate      DateTime?
  estimatedHours     Float?
  actualHours        Float?
  reminderDate       DateTime?
  reminderTime       String?
  progressPercentage Int              @default(0)
  tags               String[]         @default([])

  // Auditing
  createdBy          String?
  updatedBy          String?
  deletedBy          String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  deletedAt          DateTime?
  version            Int              @default(1)

  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@map("tasks")
}

// 24. MEETINGS
model Meeting {
  id          String    @id @default(uuid()) @db.Uuid
  organizerId String    @db.Uuid
  organizer   Employee  @relation(fields: [organizerId], references: [id], onDelete: Restrict)
  customerId  String?   @db.Uuid
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  dealId      String?   @db.Uuid
  deal         Deal?     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  location    String?

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  version     Int       @default(1)

  @@map("meetings")
}

// 25. PRODUCT CATEGORIES
model ProductCategory {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  description String?

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  version     Int       @default(1)

  // Relations
  products    Product[]

  @@map("product_categories")
}

// 26. PRODUCTS
model Product {
  id          String          @id @default(uuid()) @db.Uuid
  categoryId  String          @db.Uuid
  category    ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  name        String
  sku         String          @unique
  price       Float
  isActive    Boolean         @default(true)

  // Auditing
  createdBy   String?
  updatedBy   String?
  deletedBy   String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?
  version     Int             @default(1)

