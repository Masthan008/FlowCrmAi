# ==========================================================
# FlowCRM AI Deployment Environment Variables
# ==========================================================

# Docker Compose Host Port Mappings (Non-conflicting with Zoho, Medisync, Edusync, Mirai-Task)
DB_HOST_PORT=45432
API_HOST_PORT=5003
WEB_HOST_PORT=7080

# Database Credentials
POSTGRES_USER=flowcrm
POSTGRES_PASSWORD=flowcrm_pass_change_me_in_prod
POSTGRES_DB=flowcrm_db

# JWT Security
JWT_SECRET=your_jwt_access_secret_key_change_me_in_prod_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_me_in_prod_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Client (Frontend) Access Settings
# Point these to your domain or VPS public IP in production
CLIENT_URL=http://localhost:7080
VITE_API_URL=/api/v1
